rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the authenticated user's UID matches the document's owner ID
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Rules for user profile documents
    match /users/{userId} {
      // Users can read, create, and update their own profile.
      // Listing all users or deleting profiles is not allowed.
      allow get, update: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if false;
    }
    
    // Rules for flashcard sub-collections
    match /users/{userId}/flashcards/{flashcardId} {
      // A user has full read and write access to their own flashcards.
      // The `isOwner(userId)` check ensures that a user can only access flashcards
      // that are under their own `/users/{userId}` path.
      allow read, write: if isOwner(userId);
    }
  }
}
